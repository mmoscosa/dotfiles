# Ghost Protocol — Ghostty Config
# Catppuccin system-aware theme

# Font
font-family = JetBrains Mono Nerd Font
font-size = 15
font-thicken = true

# Theme (follows macOS appearance)
theme = light:catppuccin-latte,dark:catppuccin-mocha

# Window
background-opacity = 0.90
background-blur-radius = 20
macos-titlebar-style = hidden
window-padding-x = 6
window-padding-y = 6
adjust-cell-height = 2

# Cursor
cursor-style = bar
cursor-style-blink = true

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Terminal
shell-integration = detect
scrollback-limit = 50000

# Auto-attach tmux on every new window
command = /bin/zsh -lc "tmux attach -t main 2>/dev/null || tmux new-session -s main"

# Keybind passthrough for tmux (prefix = Ctrl-a)
keybind = cmd+b=text:\x01\x7a
keybind = cmd+shift+d=text:\x01\x64
keybind = cmd+u=text:\x01\x5b
